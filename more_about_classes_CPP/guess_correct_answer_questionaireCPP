//This program is a game between two players where they have to guess the correct answer for the questions and will earn points. There are two players and whoever gets the most points, wins the game unless it is a draw. Setter functions were not necessary for this program so i opted them out. Enjoy
#include <iostream>
using namespace std;

class Question
{
private:
    string question; //the question that will be asked to player
    string ans1, ans2, ans3, ans4;  //the possible answers that the player must choose
    int correctAns; //the official correct answer
    
public:

    
    //constructor: initializes the private variables
    Question(string q, string a1, string a2, string a3, string a4, int ca): question(q),ans1(a1), ans2(a2), ans3(a3), ans4(a4),correctAns(ca) {}
    
    //getter functions start
    string getQuestion() const
    { return question; }

    string getAnswer1() const
    { return ans1; }
    
    string getAnswer2() const
    { return ans2; }
    
    string getAnswer3() const
    { return ans3; }
    
    string getAnswer4() const
    { return ans4; }

    double getCorrectAnswers() const
    { return correctAns; }
    //getter functions end------------

};

int main()
{
    const int MAX = 3;  //max number of questions
    int choice;         //so player can input their choice
    
    //'trivia1' object is for the first player.
    //trivia1[0].question, trivia1[0].ans1, trivia1[0].ans2, trivia1[0].ans3, trivia[0].ans4, trivia1[0].correctAns
    Question trivia1[MAX] = {Question("What is my name?","Jeremy", "Timmy", "John", "Raul",1),
                            Question("What is my dog's name?", "Timmy", "Rinty", "Jay", "Oso",2),
                            Question("What is my school's name?", "MTSU", "TSU", "ETSU", "FIU",4) };
    
    //trivia2[0].question, trivia2[0].ans1, trivia2[0].ans2, trivia2[0].ans3, trivia2[0].ans4, trivia2[0].correctAns

    Question trivia2[MAX] = {Question("What is my name?","Jeremy", "Timmy", "John", "Raul",1),
                            Question("What is my dog's name?", "Timmy", "Rinty", "Jay", "Oso",2),
                            Question("What is my school's name?", "MTSU", "TSU", "ETSU", "FIU",4) };
    
    int point1 = 0, point2 = 0; //points that each player earns in the game
    cout << "Player 1.\n";
    cout <<"What is the answer to the following questions?\n";

    for(int i = 0; i < MAX; i++){
        cout << "Question " << i + 1 << ": " << trivia1[i].getQuestion() << endl;
        cout << "Possible answers.\n";
        cout << 1 << "." << trivia1[i].getAnswer1() << endl;
        cout << 2 << "." << trivia1[i].getAnswer2() << endl;
        cout << 3 << "." << trivia1[i].getAnswer3() << endl;
        cout << 4 << "." << trivia1[i].getAnswer4() << endl;
        cout << "Choice: ";
        cin >> choice;
        
        //sees if they earn a point or not
        if(choice == trivia1[i].getCorrectAnswers()){
            cout << "Correct.\n";
            point1++;
        }
        else
            cout << "Incorrect.\n";
        cout << endl;
    }
    
    cout << "Player 1 you earned " << point1 << " points\n";
    
    cout << "Player 2.\n";
    cout <<"What is the answer to the following questions?\n";

    for(int i = 0; i < MAX; i++){
        cout << "Question " << i + 1 << ": " << trivia2[i].getQuestion() << endl;
        cout << "Possible answers.\n";
        cout << 1 << "." << trivia2[i].getAnswer1() << endl;
        cout << 2 << "." << trivia2[i].getAnswer2() << endl;
        cout << 3 << "." << trivia2[i].getAnswer3() << endl;
        cout << 4 << "." << trivia2[i].getAnswer4() << endl;
        cout << "Choice: ";
        cin >> choice;
        
        //sees if player2 earned a point or not
        if(choice == trivia2[i].getCorrectAnswers()){
            cout << "Correct.\n";
            point2++;
        }
        else
            cout << "Incorrect.\n";
        cout << endl;
    }

    cout << "Player 2 you earned " << point2 << " points\n";
    
    //calculates who won the game or if they both win(draw)
    if(point1 > point2)
        cout << "Player 1 wins the game!\n";
    else if(point1 < point2)
        cout << "Player 2 wins the game!\n";
    else
        cout << "It was a draw!\n";

    return 0;
}

